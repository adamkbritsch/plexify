# ── Plexify environment ─────────────────────────────────────────────
# Copy to `.env` and fill in, then: docker compose up -d --build
# (.env is gitignored — it stays on your machine.)

# HOST paths (absolute paths recommended) --------------------------------------
# Your Plex music library — where Plexify places FLACs and Plex scans them:
MUSIC_DIR=/path/to/your/plex/music/library
# A working/downloads folder (staging + in-progress files):
DOWNLOADS_DIR=/path/to/a/downloads/workdir

# The URL you'll actually open the UI at. This builds the Spotify OAuth redirect
# (PUBLIC_BASE_URL/auth/spotify/callback), so set it to the real address if you reach
# Plexify from another machine or behind a reverse proxy — localhost only works when you
# run the setup wizard from the same machine.
PUBLIC_BASE_URL=http://localhost:8787

# Host-side ports
ENGINE_PORT=8787
DOWNLOADER_PORT=8788

# Optional shared bearer token between the engine and the downloader daemon. Leave blank
# for a same-host Docker network. If you set it, also set the engine's `nas_downloader_token`
# to the same value (Settings) so they authenticate.
DOWNLOADER_TOKEN=

# Where app state lives on the host (SQLite DB + secret key — keep private, gitignored):
DATA_DIR=./data
DOWNLOADER_DATA_DIR=./downloader-data
